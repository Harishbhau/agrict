<script>
// PANEL SWITCHING
function switchPanel(id){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  event && event.currentTarget && event.currentTarget.classList.add('active');
}
document.querySelectorAll('.nav-item').forEach(item=>{
  item.addEventListener('click',function(){
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    this.classList.add('active');
  });
});

// TASK TOGGLE
function toggleTask(cb){
  cb.classList.toggle('done');
  const txt = cb.nextElementSibling;
  txt.classList.toggle('done');
  if(cb.classList.contains('done')) cb.innerHTML='✓'; else cb.innerHTML='';
}

// CHAT
const responses = {
  'blight': `**Late Blight Treatment — Field 3 (Creek Buffer Zone)**\n\n🛡️ **Guardrail Active:** Mancozeb is BLOCKED (EPA 40 CFR §180.176 — 200ft creek buffer).\n\n✅ **Approved treatment:** Copper Octanoate (Certis Enclave)\n• Rate: 1.5 pt/acre · PHI: 0 days\n• Cost: ~$340 for 18 acres\n• Apply **today before Saturday** (wind forecast 18mph Sat)\n\n⚠️ **Edge case handled:** AI rescheduled Saturday application to Friday 6–9 AM to avoid drift risk to neighboring organic operation.`,
  'irrigation': `**Field 6 Irrigation Decision**\n\n📊 **Situation:**\n• Corn at V4 — critical growth stage\n• Soil VWC: 29% (target: 55–70%)\n• Water permit: 87% used (24 ac-ft remaining)\n• Requested: 8.4 ac-ft\n\n🤖 **AI Recommendation:** ✅ Approve partial (6 ac-ft)\n• Irreversible yield loss likely within 72h if denied\n• Rainwater tank has 3 ac-ft available (offset)\n• Leaves 18 ac-ft in reserve for rest of season\n\n⚖️ Full 8.4 ac-ft would be flagged for permit review.`,
  'harvest': `**Harvest Schedule — This Week**\n\n🌾 **Field 1 (Winter Wheat) — READY**\n• GDD: 1,188/1,200 (99%) ✓\n• Optimal window: **Apr 2–7**\n• Weather risk: Low (9% rain chance)\n• Auto-workflow: Combine pre-check Thu PM, elevator booked Fri 1PM\n\n🟡 **Field 4 (Alfalfa Cut 3)**\n• Window: Apr 3–5 · Queue Mower #2\n\nAll harvest tasks auto-notified to crew. Confirm workflow to finalize.`,
  'audit': `**USDA NOP Audit Prep — Apr 12 (14 Days)**\n\n🔴 **3 Outstanding Items:**\n1. **Soil Amendment Log** — Feb & Mar entries incomplete → Go to Records > Amendments\n2. **Pest Control Record** — Field 3 treatment missing manager signature\n3. **Seed Source Declaration** — Sunflower cert needed for Field 5\n\n🟢 **Completed (9/12):** Pesticide logs, water records, worker safety training, organic system plan, field maps, input material invoices, sales records, equipment cleaning records, prior year audit response.\n\n📋 **Compliance Score: 92%** — on track for certification renewal.`,
  'risk': `**Top Yield Risks — Spring 2026**\n\n🚨 **Critical:**\n• Late blight Field 3 → -18% forecast if untreated (treatment queued)\n\n⚠️ **Elevated:**\n• Water permit 87% used → rationing model active\n• Field 6 corn moisture stress → approval pending\n\n📉 **Watch:**\n• Market price volatility (corn -8% futures this week)\n• Frost risk Apr 4–5 (low probability, monitoring)\n\n**Overall season forecast: +12% above 5-yr average** if blight is treated and irrigation approved.`
};

function getResponse(msg){
  const m = msg.toLowerCase();
  if(m.includes('blight')||m.includes('treatment')||m.includes('creek')||m.includes('copper')) return responses.blight;
  if(m.includes('irrigation')||m.includes('f6')||m.includes('field 6')||m.includes('permit')) return responses.irrigation;
  if(m.includes('harvest')||m.includes('wheat')||m.includes('schedule')) return responses.harvest;
  if(m.includes('audit')||m.includes('compliance')||m.includes('nop')||m.includes('documentation')) return responses.audit;
  if(m.includes('risk')||m.includes('yield')||m.includes('forecast')) return responses.risk;
  return `I'm analyzing your farm data for: **"${msg}"**\n\nBased on current sensor readings and AI models, let me check all 6 fields and cross-reference with regulatory guardrails...\n\n✅ Query processed. For specific recommendations on crops, irrigation, pests, or compliance — try one of the suggested prompts below, or navigate to the relevant module.`;
}

function appendMsg(content, role){
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  const avatar = document.createElement('div');
  avatar.className = `msg-avatar ${role==='bot'?'bot-av':'user-av'}`;
  avatar.textContent = role==='bot'?'🌾':'👤';
  const bubble = document.createElement('div');
  bubble.className = 'msg-bubble';
  bubble.innerHTML = content.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>');
  div.appendChild(avatar); div.appendChild(bubble);
  const msgs = document.getElementById('chatMessages');
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function sendMessage(){
  const inp = document.getElementById('chatInput');
  const val = inp.value.trim();
  if(!val) return;
  appendMsg(val,'user');
  inp.value='';
  setTimeout(()=>appendMsg(getResponse(val),'bot'),600);
}

function sendChip(txt){
  document.getElementById('chatInput').value = txt;
  switchPanel('chat');
  document.querySelectorAll('.nav-item').forEach((n,i)=>{if(i===6)n.classList.add('active');else n.classList.remove('active');});
  setTimeout(sendMessage, 100);
}

function handleKey(e){
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}
}
